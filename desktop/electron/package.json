{
  "name": "@contaflow/desktop",
  "version": "1.0.0",
  "description": "ContaFlow - Sistema Contabil Inteligente",
  "main": "main.js",
  "author": {
    "name": "Marcelo Desenvolvedor",
    "email": "mareclobradrj@gmail.com"
  },
  "scripts": {
    "dev": "set PORTABLE_MODE=0 && electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:all": "npm run build && npm run build:portable"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.contaflow.desktop",
    "productName": "ContaFlow",
    "copyright": "Copyright © 2026 Marcelo Desenvolvedor",
    "directories": {
      "output": "../dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "installer.html",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../../backend/dist",
        "to": "server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../backend/node_modules/.prisma",
        "to": "server/node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../backend/node_modules/@prisma",
        "to": "server/node_modules/@prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../frontend/dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "ContaFlow-Setup-${version}.${ext}",
      "signAndEditExecutable": false,
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ContaFlow",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "license": "LICENSE.txt"
    },
    "portable": {
      "artifactName": "ContaFlow-Portable-${version}.${ext}"
    }
  }
}
