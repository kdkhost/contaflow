{
  "name": "@contaflow/portable",
  "version": "1.0.0",
  "description": "ContaFlow - Modo Portatil (Pendrive)",
  "main": "main.js",
  "author": {
    "name": "Marcelo Desenvolvedor",
    "email": "mareclobradrj@gmail.com"
  },
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.contaflow.portable",
    "productName": "ContaFlow-Portable",
    "copyright": "Copyright © 2026 Marcelo Desenvolvedor",
    "directories": {
      "output": "../dist-portable"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../../backend",
        "to": "server/backend",
        "filter": ["**/*", "!node_modules", "!.git", "!data/*.db"]
      },
      {
        "from": "../../frontend/dist",
        "to": "server/frontend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "ContaFlow-Portable-${version}.${ext}"
    },
    "portable": {
      "artifactName": "ContaFlow-Portable-${version}.${ext}",
      "splashImage": "assets/splash.png"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}
