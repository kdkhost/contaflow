{
  "name": "@contaflow/portable",
  "version": "1.0.0",
  "description": "ContaFlow - Modo Portatil (Pendrive)",
  "scripts": {
    "build": "pkg dist/index.js --targets node20-win-x64 --output contaflow-portable.exe",
    "build:linux": "pkg dist/index.js --targets node20-linux-x64 --output contaflow-portable",
    "package": "npm run build"
  },
  "bin": "start.js",
  "pkg": {
    "assets": ["frontend/**/*", "server/**/*"],
    "outputPath": "dist-portable"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}