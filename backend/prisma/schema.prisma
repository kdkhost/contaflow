  totalParcelas   Int?          @map("total_parcelas")
  contaContabilId String?       @map("conta_contabil_id") 
  contaBancariaId String?       @map("conta_bancaria_id") 
  centroCusto     String?       @map("centro_custo")
  observacoes     String?
  anexo           String?
  criadoEm        DateTime      @default(now()) @map("criado_em")
  atualizadoEm    DateTime      @updatedAt @map("atualizado_em")

  empresa         Empresas      @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
  @@index([tenantId])
  @@index([dataVencimento])
  @@index([status])
  @@map("contas_pagar")
}

