# ContaFlow - Configuracoes de Ambiente

# Ambiente
NODE_ENV=development
PORT=3333
HOST=0.0.0.0

# Banco de Dados (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/contaflow?schema=public"

# Banco de Dados (SQLite - modo portable)
DATABASE_URL_SQLITE="./data/contaflow.db"
DATABASE_ADAPTER=sqlite

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=contaflow-jwt-secret-super-secure-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=contaflow-refresh-secret-super-secure-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Certificado Digital
CERTIFICADO_PADRAO=A1

# OpenAI (Opcional - IA para lancamentos)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contaflow@sistema.com.br

# WhatsApp (Z-API)
ZAPI_INSTANCE=
ZAPI_TOKEN=

# Graficos
GRAPHIFY_ENABLED=true

# Logs
LOG_LEVEL=info
LOG_DIR=./logs

# Backup
BACKUP_DIR=./backups
BACKUP_CRON=0 2 * * *
BACKUP_CRIPTOGRAFAR=true

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true